NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=botauth
DB_USERNAME=botauth
DB_PASSWORD=your_db_pass

# ── Sessions ─────────────────────────────────────────────────────────────────
# Random 64-char string. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_64_char_string

# ── Bot Auth (Ed25519) ───────────────────────────────────────────────────────
# Generate with: npm run keygen
# Private key: 128 hex chars (64-byte libsodium secret key = 32-byte seed + 32-byte pubkey)
BOT_ED25519_PRIVATE_KEY=
# Public key: 64 hex chars (32-byte Ed25519 public key — also embed in DLL/loader)
BOT_ED25519_PUBLIC_KEY=

# ── Release Storage ──────────────────────────────────────────────────────────
# Absolute path to directory where DLL/loader binaries are stored.
# Must NOT be inside client/public or any web-accessible directory.
BOT_PRIVATE_DIR=C:\xampp\private\releases
# BOT_PRIVATE_DIR=/var/www/private/releases
